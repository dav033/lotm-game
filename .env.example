DATABASE_URL="file:./data/game.db"
ADMIN_PASSWORD="cambiar-esta-contrasena"
ADMIN_SESSION_SECRET="cambiar-por-un-secreto-largo"

# MCP y biblioteca independiente del generador de cartas
CARDS_DB_PATH="./data/cards.db"
CARDS_EXPORT_DIR="./data/card-exports"
CARDS_MCP_HOST="127.0.0.1"
CARDS_MCP_PORT="3101"
# Obligatorio si CARDS_MCP_HOST deja de ser local.
CARDS_MCP_TOKEN=""
# URL publica opcional usada en los enlaces de descarga del MCP HTTP.
CARDS_MCP_PUBLIC_URL=""
# Pagina que se abre sola en el navegador al guardar/editar la primera carta
# de la sesion (requiere "npm run dev" corriendo). Por defecto /cartas/vivo local.
CARDS_LIVE_VIEW_URL=""
