{
  "name": "archivo-de-misterios",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "test": "tsx --test \"src/**/*.test.ts\" \"prisma/**/*.test.ts\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "cards:mcp": "node --import tsx mcp/cards-stdio.ts",
    "cards:mcp:http": "node --import tsx mcp/cards-http.ts",
    "cards:browser": "playwright install chromium",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/adapter-better-sqlite3": "latest",
    "@prisma/client": "latest",
    "better-sqlite3": "^12.4.1",
    "framer-motion": "^12.42.2",
    "html2canvas": "^1.4.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.545.0",
    "next": "^15.5.4",
    "playwright": "^1.61.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.1.11",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.13",
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.6",
    "@types/node": "^24.6.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "dotenv": "^17.2.3",
    "eslint": "^9.36.0",
    "eslint-config-next": "^15.5.4",
    "prisma": "latest",
    "tailwindcss": "^4.1.13",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2"
  }
}
